APP_NAME="Du Lich Viet"
APP_ENV=production
APP_KEY=                        # Chạy: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi

LOG_CHANNEL=stderr
LOG_LEVEL=error

# -------------------------------------------------------
# Database (Render MySQL / PlanetScale / Railway / Aiven)
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=du_lich_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# -------------------------------------------------------
# Session & Cache — dùng file hoặc database trên production
# -------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# -------------------------------------------------------
# Filesystem — public disk cho upload ảnh
# -------------------------------------------------------
FILESYSTEM_DISK=public

# -------------------------------------------------------
# Mail — cấu hình SMTP thật khi deploy (ví dụ: Mailtrap, Gmail)
# -------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM_ADDRESS="noreply@dulichviet.com"
MAIL_FROM_NAME="${APP_NAME}"
